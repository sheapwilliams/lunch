# Copy this file to .env-prod (production) or .env-test (test) and fill in values.
# Never commit .env-prod or .env-test — they are excluded by .gitignore.

# Flask session signing key. Generate once with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Use the same value across restarts and deploys so sessions survive.
SECRET_KEY=

# Stripe API keys (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLIC_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Directory where the database and session files are stored inside the container.
DATA_DIR=/data
