# Version control
.git
.gitignore

# Python artifacts
__pycache__
*.pyc
*.pyo
*.pyd
.Python
.venv
.python-version

# Environment / secrets — never bake credentials into the image
.env
.env-prod
.env-test
.env.example

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# Local tooling & CI artifacts
.claude/
.pytest_cache/
.coverage
htmlcov/
tests/

# Runtime data (created at container startup)
flask_session/
instance/

# Not needed to run the app
archive/
docs/
live/
dist/
build/
*.egg-info/
README.md
LICENSE
init_db.py
